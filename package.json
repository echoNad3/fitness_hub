{
  "name": "fitness_hub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run brand:check && tsc -b && vite build",
    "android:sync": "cross-env CAPACITOR_BUILD=true npm run build && cap sync android",
    "android:open": "cap open android",
    "brand:sync": "node scripts/sync-brand-assets.mjs",
    "brand:check": "node scripts/sync-brand-assets.mjs --check",
    "generate-pwa-assets": "npm run brand:sync",
    "generate-android-assets": "npm run brand:sync",
    "lint": "oxlint",
    "security:rls": "node --experimental-strip-types scripts/check-supabase-rls.ts",
    "test": "npm run brand:check && node --experimental-strip-types --test tests/domain.test.ts tests/dataValidation.test.ts tests/cloudSync.test.ts tests/apkVersion.test.ts tests/timeFormat.test.ts tests/storage.test.ts tests/restTimerState.test.ts tests/historyPagination.test.ts tests/recovery.test.ts",
    "test:e2e": "node scripts/run-e2e.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.108.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@playwright/test": "^1.58.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^10.1.0",
    "oxlint": "^1.69.0",
    "sharp": "^0.33.5",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0"
  }
}
