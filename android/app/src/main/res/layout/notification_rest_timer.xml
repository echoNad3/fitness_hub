<?xml version="1.0" encoding="utf-8"?>
<!-- Content area of the rest-timer notification: a label and a big live countdown. Rendered
     inside DecoratedCustomViewStyle, which supplies the app icon header and day/night colors. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/rest_timer_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rest timer"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Title" />

    <Chronometer
        android:id="@+id/rest_timer_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Title"
        android:textSize="28sp"
        android:textStyle="bold" />
</LinearLayout>
