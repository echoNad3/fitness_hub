<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <!-- Dark window + bars so the WebView load phase never flashes black/grey. -->
        <item name="android:windowBackground">#FF252730</item>
        <item name="android:statusBarColor">#FF252730</item>
        <item name="android:navigationBarColor">#FF252730</item>
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <!-- Android 12+ draws its own system splash (app icon on windowSplashScreenBackground) and
             ignores the drawable above; without this it defaults to black. -->
        <item name="windowSplashScreenBackground">#FF252730</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenBehavior">icon_preferred</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <!-- Keep the cold-start splash dark so the system bars don't flash grey around the app's
             background before the WebView loads. -->
        <item name="android:windowBackground">#FF252730</item>
        <item name="android:statusBarColor">#FF252730</item>
        <item name="android:navigationBarColor">#FF252730</item>
    </style>
</resources>
